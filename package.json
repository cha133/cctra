{
  "name": "cctra",
  "version": "0.3.2",
  "description": "Local LLM subscription protocol converter + plugin host. Runs a local HTTP server on 127.0.0.1:3133 that translates between OpenAI Chat / OpenAI Responses / Anthropic Messages, with a tier-based model aliasing system and local-path plugin support.",
  "type": "module",
  "bin": {
    "cctra": "bin/cctra.js"
  },
  "files": [
    "bin/",
    "src/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "serve": "bun run src/index.ts serve",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "verify": "bunx tsc --noEmit && bun test",
    "package": "pwsh -ExecutionPolicy Bypass -File scripts/package.ps1",
    "release": "pwsh -ExecutionPolicy Bypass -File scripts/publish.ps1"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "llm",
    "proxy",
    "openai",
    "anthropic",
    "claude-code",
    "codex",
    "translation",
    "plugin"
  ],
  "license": "MIT",
  "author": "cha133",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cha133/cctra.git"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "commander": "^15.0.0",
    "confbox": "^0.2.4",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
